# 服务配置
SERVER_PORT=3000
NODE_ENV=production
CLUSTER_MODE=true
CLUSTER_WORKERS=4

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=power_inspection

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_LOCK_TTL=5000

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE_ALARM=alarm_queue
RABBITMQ_QUEUE_DATA=data_queue

# 告警推送配置
ALARM_WEBHOOK_URL=http://localhost:8080/alarm
ALARM_EMAIL_HOST=smtp.example.com
ALARM_SMS_GATEWAY=http://sms.example.com/send

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log
