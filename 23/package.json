{
  "name": "power-inspection-api-cluster",
  "version": "1.0.0",
  "description": "电力巡检终端状态上报与阈值告警 API 集群",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:cluster": "node dist/cluster.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:cluster": "ts-node-dev --respawn --transpile-only src/cluster.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "amqplib": "^0.10.3",
    "typeorm": "^0.3.17",
    "mysql2": "^3.6.0",
    "joi": "^17.11.0",
    "axios": "^1.5.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.3",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "cluster": "^0.7.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.19",
    "@types/node": "^20.8.6",
    "@types/amqplib": "^0.10.3",
    "@types/uuid": "^9.0.5",
    "@types/compression": "^1.7.4",
    "typescript": "^5.2.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.6",
    "ts-jest": "^29.1.1"
  }
}
