SERVER_HOST=0.0.0.0
SERVER_PORT=8000

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

USE_LOCAL_MODEL=false
LOCAL_MODEL_PATH=./models/all-MiniLM-L6-v2

AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY=1.0
AI_RETRY_MAX_DELAY=30.0
AI_REQUEST_TIMEOUT=120
AI_MAX_CONCURRENT=10

DATABASE_URL=postgresql://user:password@localhost:5432/doc_ai
DATABASE_ECHO=false

REDIS_URL=redis://localhost:6379/0

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=209715200

PARSE_TIMEOUT=300
MAX_PAGES_PER_CHUNK=50
MAX_TEXT_LENGTH=100000

MAX_HIGHLIGHT_PARAGRAPHS=5
MAX_HIGHLIGHT_SENTENCES=10
MIN_SENTENCE_LENGTH=20
USE_AI_HIGHLIGHT=true

BATCH_PROCESSING_LIMIT=500
MAX_CONCURRENT_TASKS=20
TASK_TIMEOUT=600
PAUSE_BETWEEN_DOCS=0.05
BATCH_WORKER_COUNT=4
ENABLE_CACHE=true

CLASSIFICATION_THRESHOLD=0.6
MAX_TEXT_FOR_AI=8000

WORKER_COUNT=4

LOG_LEVEL=INFO
LOG_FILE=./logs/doc_ai.log
