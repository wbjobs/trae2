NODE_ENV=production
PORT=3000
CLUSTER_INSTANCES=4

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

API_KEYS=device_key_001,device_key_002,device_key_003

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000
RATE_LIMIT_SKIP_SUCCESS=false
DEVICE_RATE_LIMIT=100
BATCH_RATE_LIMIT=50
QUERY_RATE_LIMIT=60

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

QUEUE_NAME=device_data_queue
QUEUE_CONCURRENCY=20
QUEUE_BATCH_SIZE=50
QUEUE_MAX_RETRIES=5
QUEUE_BACKOFF_DELAY=2000
STALLED_INTERVAL=30000
MAX_STALLED_COUNT=3

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=industrial-org
INFLUX_BUCKET=device_data
INFLUX_BATCH_SIZE=500
INFLUX_FLUSH_INTERVAL=1000
INFLUX_MAX_BUFFER_LINES=10000
INFLUX_RETRY_ATTEMPTS=3
INFLUX_RETRY_DELAY=1000

ALERTING_ENABLED=true
ALERT_DEFAULT_COOLDOWN=300000
ALERT_MAX_PER_RULE=100

LOG_LEVEL=info
LOG_FILE=logs/app.log

QUEUE_DEPTH_THRESHOLD=1000
QUEUE_DEPTH_WARNING=500
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
METRICS_ENDPOINT=/api/monitoring/metrics
CLUSTER_HEARTBEAT_INTERVAL=10000
CLUSTER_INSTANCE_TIMEOUT=60000
