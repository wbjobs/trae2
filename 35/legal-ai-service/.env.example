APP_NAME="Legal AI Service"
APP_VERSION="1.0.0"
DEBUG=false

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese
EMBEDDING_DIMENSION=768
DEVICE=cpu

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

VECTOR_INDEX_PATH=data/vector_index
LEGAL_PROVISIONS_PATH=data/legal_provisions.json
CASE_DATA_PATH=data/cases.json

TOP_K_PROVISIONS=10
TOP_K_CASES=5
SIMILARITY_THRESHOLD=0.6

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4

MAX_FILE_SIZE=10485760

BUSINESS_SERVICE_URL=http://localhost:8080
BUSINESS_SERVICE_TIMEOUT=30

RATE_LIMIT_PER_MINUTE=60
API_KEYS=your-api-key-1,your-api-key-2

BATCH_PROCESSING_MAX_WORKERS=8
