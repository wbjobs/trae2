<Window x:Class="StudioAudioMatrix.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudioAudioMatrix.ViewModels;assembly=StudioAudioMatrix"
        xmlns:views="clr-namespace:StudioAudioMatrix.Views;assembly=StudioAudioMatrix"
        xmlns:conv="clr-namespace:StudioAudioMatrix.Converters;assembly=StudioAudioMatrix"
        xmlns:models="clr-namespace:StudioAudioMatrix.Models;assembly=StudioAudioMatrix"
        Title="多功能演播室音频矩阵布局与音效预演系统" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource TextForeground}">
    <Window.Resources>
        <vm:MainViewModel x:Key="MainVm"/>
        <conv:DevicePositionConverter x:Key="DevicePositionConverter"/>
    </Window.Resources>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="New_Executed"/>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed"/>
    </Window.CommandBindings>
    <DockPanel DataContext="{StaticResource MainVm}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建工程(_N)" Command="ApplicationCommands.New" InputGestureText="Ctrl+N"/>
                <MenuItem Header="打开工程(_O)" Command="ApplicationCommands.Open" InputGestureText="Ctrl+O"/>
                <MenuItem Header="保存工程(_S)" Command="ApplicationCommands.Save" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="退出(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="矩阵布局" IsCheckable="True" IsChecked="True" Click="ToggleMatrixLayout"/>
                <MenuItem Header="设备列表" IsCheckable="True" IsChecked="True" Click="ToggleDeviceList"/>
                <MenuItem Header="区域标注" IsCheckable="True" IsChecked="True" Click="ToggleZonePanel"/>
                <MenuItem Header="模板库" IsCheckable="True" IsChecked="True" Click="ToggleTemplatePanel"/>
                <MenuItem Header="时间轴" IsCheckable="True" IsChecked="True" Click="ToggleTimeline"/>
                <MenuItem Header="矩阵路由" IsCheckable="True" IsChecked="True" Click="ToggleMatrixGrid"/>
            </MenuItem>
            <MenuItem Header="仿真(_S)">
                <MenuItem Header="连接外置仿真器" Command="{Binding ConnectSimulatorCommand}"/>
                <MenuItem Header="开始声场计算" Command="{Binding ComputeSoundFieldCommand}"/>
            </MenuItem>
            <MenuItem Header="播放(_P)">
                <MenuItem Header="播放/继续" Command="{Binding StartPlaybackCommand}" InputGestureText="Space"/>
                <MenuItem Header="暂停" Command="{Binding PausePlaybackCommand}"/>
                <MenuItem Header="停止" Command="{Binding StopPlaybackCommand}"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusMessage}"/>
            <Separator/>
            <ProgressBar Value="{Binding LoadProgress}" Width="100" Height="12"
                         Visibility="{Binding LoadProgress, Converter={StaticResource ProgressVisibilityConverter}}"/>
            <StatusBarItem Content="{Binding LoadProgressMessage}"/>
            <Separator/>
            <StatusBarItem Content="{Binding ZoneStatsText}"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock>
                    <Run Text="仿真器:"/>
                    <Run Text="{Binding ConnectionStatus}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <TabControl Grid.Row="0" Grid.Column="0" Margin="4">
                <TabItem Header="设备">
                    <DockPanel>
                        <ToolBar DockPanel.Dock="Top">
                            <Button Content="+" Command="{Binding AddDeviceCommand}" Width="28"/>
                            <Button Content="-" Command="{Binding RemoveDeviceCommand}" Width="28"/>
                        </ToolBar>
                        <ListBox ItemsSource="{Binding CurrentProject.Devices}" SelectedItem="{Binding SelectedDevice}"
                                 DisplayMemberPath="Name"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="区域">
                    <views:ZoneEditorPanel DataContext="{StaticResource MainVm}"/>
                </TabItem>
                <TabItem Header="模板">
                    <views:TemplateBrowser DataContext="{StaticResource MainVm}"/>
                </TabItem>
            </TabControl>

            <TabControl Grid.Row="0" Grid.Column="1" Margin="4">
                <TabItem Header="矩阵布局">
                    <Grid>
                        <views:MatrixLayoutView DataContext="{StaticResource MainVm}"/>
                        <views:SoundZoneOverlay DataContext="{StaticResource MainVm}"
                                                IsHitTestVisible="False"
                                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                </TabItem>
                <TabItem Header="矩阵路由">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ToolBar Grid.Row="0">
                            <TextBlock Text="路由矩阵" Margin="4" FontWeight="Bold"/>
                        </ToolBar>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentProject.MatrixCells}"
                                  AutoGenerateColumns="False" CanUserSortColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="行" Binding="{Binding Row}" Width="40" IsReadOnly="True"/>
                                <DataGridTextColumn Header="列" Binding="{Binding Column}" Width="40" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="50">
                                    <DataGridCheckBoxColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <EventSetter Event="CheckBox.Click" Handler="MatrixCell_Click"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.CellStyle>
                                </DataGridCheckBoxColumn>
                                <DataGridTemplateColumn Header="增益" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Slider Minimum="0" Maximum="2" Value="{Binding Gain}" IsEnabled="{Binding IsActive}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="声场分布">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ToolBar Grid.Row="0">
                            <Button Content="重新计算" Command="{Binding ComputeSoundFieldCommand}" Style="{StaticResource ToolButton}"/>
                            <Separator/>
                            <TextBlock Text="覆盖率:" Margin="10,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SoundFieldCoverage, StringFormat={}{0:P2}}" VerticalAlignment="Center"/>
                            <Separator/>
                            <TextBlock Text="耗时:" Margin="5,0,2,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LastComputationMs, StringFormat={}{0:F1}ms}" VerticalAlignment="Center"/>
                        </ToolBar>
                        <Canvas Grid.Row="1" Background="{StaticResource CanvasBackground}" x:Name="SoundFieldCanvas"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                <GroupBox Header="播放控制" Margin="0,0,0,4">
                    <StackPanel>
                        <ToolBar>
                            <Button Content="▶" Command="{Binding StartPlaybackCommand}" Width="40" Height="32" FontSize="14"/>
                            <Button Content="⏸" Command="{Binding PausePlaybackCommand}" Width="40" Height="32" FontSize="14"/>
                            <Button Content="⏹" Command="{Binding StopPlaybackCommand}" Width="40" Height="32" FontSize="14"/>
                        </ToolBar>
                        <Slider Margin="8" Minimum="0" Maximum="100" Value="{Binding TimelinePlayer.PlayheadMs}"/>
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <TextBlock Text="速度:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider Minimum="0.5" Maximum="2" Value="{Binding TimelinePlayer.PlaybackSpeed}" Width="120"/>
                            <TextBlock Text="{Binding TimelinePlayer.PlaybackSpeed, StringFormat={}{0:F1}x}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="设备属性" DataContext="{Binding SelectedDevice}" Margin="0,0,0,4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" Margin="4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="类型:" Margin="4"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" SelectedValue="{Binding Type}" SelectedValuePath="Tag" Margin="2">
                                <ComboBoxItem Content="主扩音箱" Tag="{x:Static models:DeviceType.MainSpeaker}"/>
                                <ComboBoxItem Content="低音炮" Tag="{x:Static models:DeviceType.Subwoofer}"/>
                                <ComboBoxItem Content="环绕" Tag="{x:Static models:DeviceType.Surround}"/>
                                <ComboBoxItem Content="吸顶" Tag="{x:Static models:DeviceType.Ceiling}"/>
                                <ComboBoxItem Content="舞台返听" Tag="{x:Static models:DeviceType.StageMonitor}"/>
                                <ComboBoxItem Content="麦克风" Tag="{x:Static models:DeviceType.Microphone}"/>
                                <ComboBoxItem Content="线阵列" Tag="{x:Static models:DeviceType.LineArray}"/>
                            </ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="X (m):" Margin="4"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding X}" Margin="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Y (m):" Margin="4"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Y}" Margin="2"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Z (m):" Margin="4"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Z}" Margin="2"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="增益:" Margin="4"/>
                            <Slider Grid.Row="5" Grid.Column="1" Minimum="0" Maximum="2" Value="{Binding Gain}" Margin="2"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="延迟(ms):" Margin="4"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding DelayMs}" Margin="2"/>
                        </Grid>
                    </ScrollViewer>
                </GroupBox>
                <GroupBox Header="轨道列表">
                    <DockPanel>
                        <ToolBar DockPanel.Dock="Top">
                            <Button Content="+" Command="{Binding AddTrackCommand}" Width="28"/>
                        </ToolBar>
                        <ListBox ItemsSource="{Binding CurrentProject.Tracks}" SelectedItem="{Binding SelectedTrack}"
                                 DisplayMemberPath="Name"/>
                    </DockPanel>
                </GroupBox>
            </StackPanel>

            <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Height="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource TextBoxBorder}" Margin="0,2"/>

            <GroupBox Grid.Row="2" Grid.ColumnSpan="3" Header="时间轴" Margin="4,0">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Top">
                        <Button Content="添加事件" Command="{Binding AddEventCommand}" Style="{StaticResource ToolButton}"/>
                    </ToolBar>
                    <DataGrid ItemsSource="{Binding SelectedTrack.Events}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="开始(ms)" Binding="{Binding StartTimeMs}" Width="80"/>
                            <DataGridTextColumn Header="时长(ms)" Binding="{Binding DurationMs}" Width="80"/>
                            <DataGridComboBoxColumn Header="效果类型" SelectedValueBinding="{Binding EffectType}" Width="100">
                                <DataGridComboBoxColumn.ItemsSource>
                                    <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=System.Runtime">
                                        <sys:String>Tone</sys:String>
                                        <sys:String>Noise</sys:String>
                                        <sys:String>Sweep</sys:String>
                                        <sys:String>Reverb</sys:String>
                                        <sys:String>Delay</sys:String>
                                    </x:Array>
                                </DataGridComboBoxColumn.ItemsSource>
                            </DataGridComboBoxColumn>
                            <DataGridTemplateColumn Header="增益" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Slider Minimum="0" Maximum="1" Value="{Binding Gain}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
