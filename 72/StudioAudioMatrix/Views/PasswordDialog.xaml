<Window x:Class="StudioAudioMatrix.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入工程密码" Height="180" Width="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource TextForeground}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="请输入工程文件密码:" Margin="0,0,0,10" FontSize="14"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="1" Height="32"
                     BorderBrush="{StaticResource TextBoxBorder}"
                     Background="{StaticResource TextBoxBackground}"
                     Foreground="{StaticResource TextForeground}"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Click="Cancel_Click" Width="80" Margin="0,0,10,0" Style="{StaticResource DialogButton}"/>
            <Button Content="确定" Click="Ok_Click" Width="80" Style="{StaticResource AccentButton}"/>
        </StackPanel>
    </Grid>
</Window>
