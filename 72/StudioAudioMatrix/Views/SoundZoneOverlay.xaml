<UserControl x:Class="StudioAudioMatrix.Views.SoundZoneOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:StudioAudioMatrix.Models;assembly=StudioAudioMatrix"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <ItemsControl ItemsSource="{Binding CurrentProject.Zones}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <Canvas/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
                <Setter Property="Canvas.Left">
                    <Setter.Value>
                        <MultiBinding Converter="{StaticResource ZonePositionConverter}">
                            <Binding Path="X"/>
                            <Binding Path="DataContext.CurrentProject.StudioWidth" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                    </Setter.Value>
                </Setter>
                <Setter Property="Canvas.Top">
                    <Setter.Value>
                        <MultiBinding Converter="{StaticResource ZonePositionConverter}">
                            <Binding Path="Z"/>
                            <Binding Path="DataContext.CurrentProject.StudioDepth" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                    </Setter.Value>
                </Setter>
            </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type models:SoundZone}">
                <Border BorderBrush="{Binding ColorHex}" BorderThickness="2" CornerRadius="3"
                        Background="#33333333" Padding="4,2"
                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                        Width="{Binding Width}" Height="{Binding Depth}">
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="White" FontWeight="Bold"/>
                        <TextBlock FontSize="9" Foreground="#CCCCCC">
                            <Run Text="目标:"/>
                            <Run Text="{Binding TargetSPL, StringFormat={}{0:F0} dB}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
