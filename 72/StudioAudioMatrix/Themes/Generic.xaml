<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:StudioAudioMatrix.Converters;assembly=StudioAudioMatrix">

    <Color x:Key="PrimaryColor">#FF1E88E5</Color>
    <Color x:Key="DarkColor">#FF1A1A2E</Color>
    <Color x:Key="PanelColor">#FF16213E</Color>
    <Color x:Key="AccentColor">#FF0F3460</Color>
    <Color x:Key="HighlightColor">#FFE94560</Color>
    <Color x:Key="TextColor">#FFEAEAEA</Color>
    <Color x:Key="SubtleTextColor">#FFB0B0B0</Color>

    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource DarkColor}"/>
    <SolidColorBrush x:Key="PanelBackground" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="ToolbarBackground" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="CanvasBackground" Color="#FF0F1419"/>
    <SolidColorBrush x:Key="TextForeground" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubtleText" Color="{StaticResource SubtleTextColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="DeviceFill" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="DeviceStroke" Color="#FF4FC3F7"/>
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF0A0F1A"/>
    <SolidColorBrush x:Key="TextBoxBorder" Color="#FF2A3A5A"/>
    <SolidColorBrush x:Key="CellActive" Color="#FF4CAF50"/>
    <SolidColorBrush x:Key="CellInactive" Color="#FF37474F"/>

    <conv:DevicePositionConverter x:Key="DevicePositionConverter"/>
    <conv:ZonePositionConverter x:Key="ZonePositionConverter"/>
    <conv:DeviceTypeToColorConverter x:Key="DeviceTypeToColorConverter"/>
    <conv:SPLToColorConverter x:Key="SPLToColorConverter"/>
    <conv:ProgressVisibilityConverter x:Key="ProgressVisibilityConverter"/>
    <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="ToolButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#66FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogButton" TargetType="Button">
        <Setter Property="Background" Value="#FF3A4A5A"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FF4A5A6A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF42A5F5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource SubtleText}"/>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TextBoxBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#331E88E5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TextBoxBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TextBoxBorder}"/>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Background" Value="{StaticResource TextBoxBorder}"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="RowBackground" Value="Transparent"/>
        <Setter Property="AlternatingRowBackground" Value="#0DFFFFFF"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TextBoxBorder}"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{StaticResource TextBoxBorder}"/>
        <Setter Property="Width" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
</ResourceDictionary>
