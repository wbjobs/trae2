{
  "name": "node-telemetry-gateway",
  "version": "1.0.0",
  "description": "分布式节点状态遥测网关系统",
  "main": "gateway-server/index.js",
  "scripts": {
    "gateway": "node gateway-server/index.js",
    "collector": "node collector/index.js",
    "persistence": "node persistence/index.js",
    "frontend": "cd frontend && npm run dev",
    "install-all": "npm install && cd frontend && npm install",
    "dev": "concurrently \"npm run gateway\" \"npm run collector\" \"npm run persistence\" \"npm run frontend\""
  },
  "keywords": ["telemetry", "gateway", "node-monitoring"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "mysql2": "^3.6.5",
    "redis": "^4.6.11",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "ws": "^8.14.2",
    "concurrently": "^8.2.2"
  }
}
