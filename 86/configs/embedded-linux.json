      "poll_interval_ms": 30000,
      "settings": {
        "revision": "c03112",
        "serial": "10000000abcdef12"
      }
    }
  ],
  "collection_rules": [
    {
      "rule_id": "rule-realtime",
      "name": "实时采集规则",
      "enabled": true,
      "hardware_types": ["Sensor"],
      "collection_interval_ms": 100,
      "timeout_ms": 500,
      "max_retries": 1,
      "filters": ["edge_detection", "debounce"],
      "aggregate": false
    },
    {
      "rule_id": "rule-system",
      "name": "系统状态规则",
      "enabled": true,
      "hardware_types": ["Cpu", "Memory"],
      "collection_interval_ms": 2000,
      "timeout_ms": 3000,
      "max_retries": 2,
      "filters": [],
      "aggregate": true
    },
    {
      "rule_id": "rule-storage",
      "name": "存储规则",
      "enabled": true,
      "hardware_types": ["Disk"],
      "collection_interval_ms": 10000,
      "timeout_ms": 5000,
      "max_retries": 2,
      "filters": ["low_space_warning"],
      "aggregate": true
    },
    {
      "rule_id": "rule-connectivity",
      "name": "连接性规则",
      "enabled": true,
      "hardware_types": ["Network", "ExternalDevice"],
      "collection_interval_ms": 5000,
      "timeout_ms": 3000,
      "max_retries": 3,
      "filters": ["connection_loss"],
      "aggregate": true
    },
    {
      "rule_id": "rule-device-info",
      "name": "设备信息规则",
      "enabled": true,
      "hardware_types": ["Motherboard"],
      "collection_interval_ms": 30000,
      "timeout_ms": 5000,
      "max_retries": 1,
      "filters": [],
      "aggregate": false
    }
  ],
