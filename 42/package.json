{
  "name": "railway-communication-monitor",
  "version": "1.0.0",
  "description": "轨道交通车载通信单元信道状态监控系统",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "signaling": "node backend/services/signalingService.js",
    "analysis": "node backend/services/analysisService.js",
    "sync": "node backend/services/syncService.js",
    "frontend": "cd frontend && npm run dev",
    "all": "concurrently \"npm run signaling\" \"npm run analysis\" \"npm run sync\" \"npm run frontend\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "mongoose": "^8.0.3",
    "redis": "^4.6.12",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
