# ============================================
# 油气管道阴极保护参数采集与阈值告警 API 服务集群
# 环境配置示例文件
# 复制为 .env 并修改实际值
# ============================================

# 服务基础配置
APP_ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=200

# InfluxDB 配置
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=cp-org
INFLUXDB_BUCKET=cp-monitor

# 消息队列配置
MQ_BROKER_URL=redis://localhost:6379/1
MQ_QUEUE_NAME=cp_alarm_queue

# 集群配置
NODE_ID=node-1
CLUSTER_NAME=cp-monitor-cluster
LB_STRATEGY=round_robin

# 限流配置
RATE_LIMIT=6000
MAX_CONNECTIONS=5000
BATCH_SIZE=100

# 调度配置
SCHEDULER_TZ=Asia/Shanghai
HEARTBEAT=10

# 告警推送配置
ALARM_CHANNELS=email,sms,webhook
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password
WEBHOOK_URL=https://your-webhook-endpoint.com/api/alarm
SMS_API_URL=https://sms-api.example.com/send
SMS_API_KEY=your-sms-api-key

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/cp_monitor.log