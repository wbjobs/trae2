{
  "name": "hardware-tuner",
  "version": "1.0.0",
  "description": "Cross-platform desktop client for hardware peripheral parameter tuning",
  "main": "dist/main/index.js",
  "author": "Tuner Team",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"tsc -w -p tsconfig.main.json\" \"electron .\"",
    "typecheck": "tsc --noEmit",
    "test:diagnostic": "ts-node -P tsconfig.main.json src/main/communication/diagnostic.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
