# Redis Broker for Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# InfluxDB Configuration
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_ORG=cfd_org
INFLUXDB_BUCKET=cfd_results
INFLUXDB_TOKEN=your_influxdb_token_here

# InfluxDB v1.x Compatibility (optional)
INFLUXDB_V1_DATABASE=cfd_db
INFLUXDB_V1_USERNAME=admin
INFLUXDB_V1_PASSWORD=admin

# CFD Compute Configuration
CFD_DEFAULT_NX=256
CFD_DEFAULT_NY=256
CFD_DEFAULT_DT=0.001
CFD_DEFAULT_NU=0.01
CFD_DEFAULT_RO=1.0
CFD_DEFAULT_ITERATIONS=1000

# Node Configuration
NODE_NAME=compute-node-01
NODE_MAX_WORKERS=4

# Monitoring
MONITORING_INTERVAL=5.0
MONITORING_RETENTION_DAYS=30
