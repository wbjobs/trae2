{
  "name": "trace-retrieval",
  "version": "1.0.0",
  "description": "Signaling trace retrieval service with Koa2 and ClickHouse",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "watch": "ts-node-dev --respawn src/index.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^0.2.0",
    "dotenv": "^16.3.1",
    "koa": "^2.14.2",
    "koa-bodyparser": "^4.4.1",
    "@koa/cors": "^5.0.0",
    "koa-router": "^12.0.0",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/koa": "^2.13.12",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-router": "^7.4.7",
    "@types/koa__cors": "^4.0.3",
    "@types/node": "^20.10.4",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
