ETH_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
START_BLOCK=0
CONFIRMATIONS=12
POLL_INTERVAL=15000
MAX_BLOCK_RANGE=5000
CONCURRENCY=3

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=eth_listener:

MONGODB_URI=mongodb://localhost:27017/eth_events

CONTRACT_ADDRESSES=0xContractAddress1,0xContractAddress2

ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook
ALERT_ENABLED=false
ALERT_EVENTS=Transfer,Approval
USE_LEGACY_ALERT=false
ALERT_RATE_LIMIT=10

LOG_LEVEL=info
